# Copy this file to .env (dev) or .env.staging and fill in values.
# Never commit .env or .env.staging — they are gitignored.

# Environment name — controls R2 path prefix (dev/ staging/ production/)
APP_ENV=dev

# R2 Storage
R2_ENABLED=true
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=your-bucket-name

# Google OAuth — must match VITE_GOOGLE_CLIENT_ID in src/frontend/.env
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Modal GPU Processing
MODAL_ENABLED=false

# Cookie security — false for http (local dev), true for https (staging/production)
SECURE_COOKIES=false

# Clear stale export jobs on startup
# true for dev (avoid ghost progress after crashes), false for staging/production
CLEAR_PENDING_JOBS_ON_STARTUP=true

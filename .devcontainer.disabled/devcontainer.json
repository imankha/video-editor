// Dev Container for permission-free Claude Code sessions.
//
// WHY: Inside this isolated container, Claude Code runs with
// permissions.defaultMode = bypassPermissions (see .devcontainer/setup.sh),
// so sessions never stop to ask you to approve a command. The HOST checkout
// keeps its normal prompts -- the bypass setting is written into the
// CONTAINER's own ~/.claude, never the host's.
//
// HOW TO USE: Command Palette -> "Dev Containers: Reopen in Container".
// The Claude Code extension reinstalls inside the container and picks up the
// bypass setting automatically. Your host login is reused (creds are copied
// in read-only from the mount below) so you don't have to /login again.
//
// NOTE: a running host session cannot be moved into the container mid-flight.
// Containerization happens at launch -- so "reopen in container" IS the
// trigger you use whenever you're about to start permission-heavy work.
{
  "name": "video-editor (Claude bypass)",
  "image": "mcr.microsoft.com/devcontainers/base:debian",

  // Non-root user is REQUIRED: bypassPermissions mode refuses to start as root.
  "remoteUser": "vscode",

  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/devcontainers/features/node:1": { "version": "20" },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.11" },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "containerEnv": {
    // Belt-and-suspenders for the CLI's root/sudo guard. We already run as the
    // non-root `vscode` user, so this is not strictly required, but harmless.
    "IS_SANDBOX": "1"
  },

  // Lets in-container code reach services running on the Windows host
  // (e.g. the shared dev Postgres on host :5432) via host.docker.internal.
  "runArgs": ["--add-host=host.docker.internal:host-gateway"],

  // Reuse the host Claude login. Mounted READ-ONLY; setup.sh copies only
  // .credentials.json out of it into the container's own ~/.claude.
  "mounts": [
    "source=${localEnv:USERPROFILE}/.claude,target=/host-claude,type=bind,readonly"
  ],

  "customizations": {
    "vscode": {
      "extensions": ["anthropic.claude-code"]
    }
  },

  // Runs once when the container is built.
  "onCreateCommand": "bash .devcontainer/setup.sh",
  // Runs on every container start -- refreshes the (rotatable) host token.
  "postStartCommand": "bash .devcontainer/auth-sync.sh"
}

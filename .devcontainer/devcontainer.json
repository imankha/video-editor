// Dev Container for permission-free Claude Code sessions.
//
// WHY: Inside this isolated container, Claude Code runs with
// permissions.defaultMode = bypassPermissions (see .devcontainer/setup.sh),
// so sessions never stop to ask you to approve a command. The HOST checkout
// keeps its normal prompts -- the bypass setting is written into the
// CONTAINER's own ~/.claude, never the host's.
//
// HOW TO USE: Command Palette -> "Dev Containers: Reopen in Container".
// The Claude Code extension installs inside the container automatically.
//
// AUTH (important): the VS Code Claude Code *extension* authenticates with its
// own sign-in flow -- it does NOT read a copied ~/.claude/.credentials.json the
// way the CLI does. So the first time you open the container, sign in once
// (open the Claude panel -> Sign in, or run `claude` in the integrated terminal
// and complete /login). That token is stored in the named volume mounted at
// ~/.claude below, so it PERSISTS across rebuilds -- you only sign in once.
// (auth-sync.sh additionally seeds the host's CLI token if the volume is empty,
// which may let the CLI skip login, but the extension panel still uses its own
// sign-in.) Same Claude subscription as the host -- no API key needed.
//
// NOTE: a running host session cannot be moved into the container mid-flight.
// Containerization happens at launch -- so "reopen in container" IS the
// trigger you use whenever you're about to start permission-heavy work.
{
  "name": "video-editor (Claude bypass)",
  "image": "mcr.microsoft.com/devcontainers/base:debian",

  // Non-root user is REQUIRED: bypassPermissions mode refuses to start as root.
  "remoteUser": "vscode",

  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/devcontainers/features/node:1": { "version": "20" },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.11" },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "containerEnv": {
    // Belt-and-suspenders for the CLI's root/sudo guard. We already run as the
    // non-root `vscode` user, so this is not strictly required, but harmless.
    "IS_SANDBOX": "1",
    // Put Claude's ENTIRE config (incl. .claude.json: MCP approvals, project
    // trust, onboarding, theme) inside the persisted ~/.claude volume. Without
    // this, .claude.json lives loose in $HOME (off the volume) and you'd redo
    // that setup on every rebuild. This dir == the named-volume mount below.
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
  },

  // Lets in-container code reach services running on the Windows host
  // (e.g. the shared dev Postgres on host :5432) via host.docker.internal.
  "runArgs": ["--add-host=host.docker.internal:host-gateway"],

  "mounts": [
    // PERSIST ~/.claude (sign-in, settings, history) across container rebuilds.
    // Without this, a rebuild wipes the home dir and you'd re-auth every time.
    // ${devcontainerId} keeps the volume stable for THIS workspace's container.
    "source=claude-code-config-${devcontainerId},target=/home/vscode/.claude,type=volume",
    // Host ~/.claude mounted READ-ONLY; auth-sync.sh seeds the CLI token from
    // here only if the volume has none yet (it never overwrites a sign-in).
    "source=${localEnv:USERPROFILE}/.claude,target=/host-claude,type=bind,readonly"
  ],

  "customizations": {
    "vscode": {
      "extensions": ["anthropic.claude-code"]
    }
  },

  // Runs once when the container is built.
  "onCreateCommand": "bash .devcontainer/setup.sh",
  // Runs on every container start.
  "postStartCommand": "bash .devcontainer/auth-sync.sh"
}

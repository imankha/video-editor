# Copy this file to .env (dev) or .env.staging and fill in values.
# Never commit .env or .env.staging — they are gitignored.

# Google OAuth client ID — must match GOOGLE_CLIENT_ID in root .env
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Backend API base URL
# Dev: leave empty (Vite proxies /api to localhost:8000)
# Staging/Production: set to the deployed backend URL
VITE_API_BASE=

# Stripe publishable key — optional override (T526)
# If not set, the frontend fetches it from the backend's GET /api/payments/config.
# Only needed if you want to bypass the backend config endpoint.
VITE_STRIPE_PUBLIC_KEY=

# Cloudflare Web Analytics token — leave empty in dev (disables analytics)
# Create a separate CF site per environment so traffic is segmented.
# Find your token at: Cloudflare Dashboard → Analytics → Web Analytics → your site
VITE_CF_ANALYTICS_TOKEN=

#!/usr/bin/env bash
# ============================================================================
# post-merge -- auto-clean task sandboxes when a branch lands on master.
# ============================================================================
# When a feature/T<id>-* branch is merged into master (via CLI or GitHub Desktop):
#   1. delete the just-merged branch REMOTE + LOCAL,
#   2. nuke its per-task container/checkout,
#   3. sweep ALL other local branches already merged into master (safe `-d`),
#   4. prune stale remote-tracking refs.
# Best-effort and BACKGROUNDED: it never blocks or fails the merge. Enable once
# per clone with:  git config core.hooksPath .githooks   Logs to /c/tmp/post-merge-cleanup.log.
#
# Caveat: GitHub Desktop runs hooks with its own PATH, where `docker` may be absent;
# in that case branches are still cleaned up but the container nuke is skipped
# (run `bash scripts/task.sh nuke <slug>` from a normal shell, or merge from CLI).
# ============================================================================
[ "$(git rev-parse --abbrev-ref HEAD 2>/dev/null)" = "master" ] || exit 0

# Only act on merges that reference a task branch (feature/T<id>...), tolerant of
# BOTH the default "...feature/T123-slug" subject AND a custom "...feature/T123: ..."
# (colon) one. Requiring the literal "feature/" prefix avoids false positives from a
# bare "T123" mentioned elsewhere in the subject (and "feature/T-auth-..." has no
# digits, so it never matches).
subj="$(git log -1 --format=%s HEAD 2>/dev/null)"
id="$(printf '%s' "$subj" | grep -oE 'feature/T[0-9]+' | grep -oE 'T[0-9]+' | head -1)"
[ -n "$id" ] || exit 0
slug="$(printf '%s' "$id" | tr 'A-Z' 'a-z')"
# Resolve the FULL branch name to delete: prefer the full token in the subject; if
# the subject only had "feature/T123" (colon style omits the slug), look it up among
# refs matching feature/T<id>-* so the real branch is still found + deleted.
branch="$(printf '%s' "$subj" | grep -oE "feature/${id}-[A-Za-z0-9._-]+" | head -1)"
[ -n "$branch" ] || branch="$(git for-each-ref --format='%(refname:short)' \
  "refs/remotes/origin/feature/${id}-*" "refs/heads/feature/${id}-*" 2>/dev/null \
  | sed 's#^origin/##' | head -1)"

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
LOG=/c/tmp/post-merge-cleanup.log
(
  echo "=== post-merge cleanup: ${branch:-feature/$id (name unresolved)} (slug $slug) ==="
  # 1. remote + local versions of the just-merged branch (if we resolved its name;
  #    if not, the merged-branch sweep in step 3 still prunes the local branch).
  if [ -n "$branch" ]; then
    git push origin --delete "$branch" 2>&1 || echo "  remote branch already gone / push skipped"
    git branch -d "$branch" 2>&1 || echo "  local branch already gone / not fully merged"
  else
    echo "  branch name unresolved from subject/refs; relying on the merged-branch sweep below"
  fi
  # 2. nuke the sandbox container + checkout
  if command -v docker >/dev/null 2>&1 && [ -f "$repo_root/scripts/task.sh" ]; then
    ( cd "$repo_root" && bash scripts/task.sh nuke "$slug" ) 2>&1 || echo "  no container to nuke"
  else
    echo "  docker not on PATH here -- skipped container nuke (run: bash scripts/task.sh nuke $slug)"
  fi
  # 3. sweep all OTHER local branches already merged into master (safe -d refuses unmerged)
  for b in $(git branch --merged master | sed 's/^[*+ ]*//' | grep -vE '^(master|main)$'); do
    git branch -d "$b" 2>&1 && echo "  pruned merged local branch: $b" || true
  done
  # 4. drop stale remote-tracking refs for branches deleted on origin
  git remote prune origin 2>&1 | sed 's/^/  /' || true
  echo "=== done $branch ==="
) >> "$LOG" 2>&1 &

exit 0
